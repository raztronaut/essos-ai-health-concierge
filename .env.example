# ---- Convex (backend / database) ----
# `npx convex dev` writes CONVEX_DEPLOYMENT / CONVEX_URL / CONVEX_SITE_URL to
# .env.local automatically. The values below are what the OTHER processes need:
#
# The agent + transport (machine path) call Convex HTTP actions at this base.
# It is the Convex deployment's SITE url (HTTP actions), e.g. http://127.0.0.1:3211
# for a local deployment, or https://<name>.convex.site when hosted.
CONVEX_SITE_URL=http://127.0.0.1:3211
# Shared secret guarding the /machine HTTP action. Set the SAME value on the
# Convex deployment: `npx convex env set CONVEX_SERVICE_SECRET <value>`.
# Leave empty for local anonymous dev (endpoint is open on localhost).
CONVEX_SERVICE_SECRET=

# ---- Dashboard + Clerk ----
# NOTE: Next.js reads env from the dashboard package dir, NOT this root file.
# Put the dashboard's public + Clerk vars in `dashboard/.env.local`:
#   NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
#   CLERK_SECRET_KEY=sk_test_...
#   CLERK_JWT_ISSUER_DOMAIN=https://<app>.clerk.accounts.dev
# Also set the issuer on Convex: `npx convex env set CLERK_JWT_ISSUER_DOMAIN ...`
# and create a Clerk JWT template named "convex" (aud: "convex").
# Without Clerk keys the dashboard runs as a "demo concierge" (auth optional).

# ---- Model (Eve agent) ----
# Essos provides a zero-data-retention key. The agent routes DIRECTLY to Anthropic
# (@ai-sdk/anthropic) using this key — no Vercel AI Gateway, so PHI never transits it.
ANTHROPIC_API_KEY=
# Anthropic model id (direct provider — hyphenated Anthropic API id, not a gateway slug)
ESSOS_AGENT_MODEL=claude-sonnet-4-5

# ---- Eve runtime ----
# Where the Eve dev server listens; the transport bridge calls this.
# `eve dev --no-ui` defaults to port 3000 (override with --port or $PORT).
EVE_BASE_URL=http://127.0.0.1:3000

# Shared secret the transport presents to Eve's session API as a bearer token.
# Optional for loopback dev (Eve admits localhost); required for a deployed/
# non-loopback agent. Set the SAME value here and in Eve's environment.
ESSOS_TRANSPORT_SECRET=

# Which seeded patient the terminal demo plays as (pat_maya | pat_diego | pat_sofia).
ESSOS_DEMO_PATIENT=pat_maya

# Comma-separated handles treated as the human concierge in iMessage groups
# (their messages never trigger an autonomous reply and signal takeover).
ESSOS_CONCIERGE_HANDLES=

# ---- Google Places (local recommendations) ----
# If unset, the search_local_places tool falls back to curated notional results.
GOOGLE_PLACES_API_KEY=

# ---- Spectrum (iMessage transport) ----
# Terminal provider needs no credentials. For the live iMessage demo use Spectrum Cloud.
SPECTRUM_PROJECT_ID=
SPECTRUM_PROJECT_SECRET=
